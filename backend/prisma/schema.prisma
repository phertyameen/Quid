// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String     @id @default(uuid()) @map("id") // UUID primary key 
  address     String     @unique @map("address") // Stellar wallet address -> unique
  email       String?    @unique @map("email") // Optional, but unique if it is provided
  displayName String?    @map("display_name")
  bio         String?    @map("bio") // Optional too
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  missions    Mission[] // one-to-many, since users can have many missions.
  // submissions Submission[] // same as missions
  // drafts      Draft[] // same as above two

  @@map("users")
}

model Mission {
  id                String    @id @default(uuid()) @map("id")
  ownerAddress      String    @map("owner_address")
  title             String    @map("title")
  descriptionCid    String    @map("description_cid")
  metadataCid       String    @map("metadata_cid")
  metadata          Json      @map("metadata")
  rewardToken       String    @map("reward_token")
  rewardAmount      String    @map("reward_amount")
  maxParticipants   Int       @default(0) @map("max_participants")
  participantsCount Int       @default(0) @map("participants_count")
  status            String    @map("status")
  aiSummary         String    @map("ai_summary")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  owner             User      @relation(fields: [ownerAddress], references: [address])
  // submissions       Submission[]
  // The above will work when submissions is merged
  

  @@index([ownerAddress])
  @@index([status, createdAt(sort: Desc)])
  @@map("missions")
}